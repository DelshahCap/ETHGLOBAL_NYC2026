# Copy to .env (gitignored) and fill in. Never commit the real .env.

# Socrata (NYC Open Data) app token — referenced by secrets.yaml as SOCRATA_APP_TOKEN.
# Get one at https://data.cityofnewyork.us (sign in -> developer settings -> app tokens).
SOCRATA_APP_TOKEN=your_socrata_app_token_here

# Private key used by the CRE CLI to sign the writeReport transaction on Arc.
# 64-hex chars, NO 0x prefix. Must hold USDC on Arc (USDC is the gas token).
CRE_ETH_PRIVATE_KEY=your_64_char_private_key_no_0x_prefix
